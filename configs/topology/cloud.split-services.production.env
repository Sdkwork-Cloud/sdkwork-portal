# cloud.split-services.production
SDKWORK_PORTAL_DEPLOYMENT_PROFILE=cloud
SDKWORK_PORTAL_SERVICE_LAYOUT=split-services
SDKWORK_PORTAL_ENVIRONMENT=production
SDKWORK_PORTAL_PROFILE_ID=cloud.split-services.production

SDKWORK_PORTAL_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:18091
SDKWORK_PORTAL_APPLICATION_PUBLIC_HTTP_URL=http://sdkwork-portal-standalone-gateway:18091

SDKWORK_API_CLOUD_GATEWAY_BIND=127.0.0.1:3900
SDKWORK_PORTAL_PLATFORM_API_GATEWAY_HTTP_URL=http://127.0.0.1:3900
SDKWORK_PORTAL_PLATFORM_API_GATEWAY_AUTOSTART=true
SDKWORK_API_CLOUD_GATEWAY_CONFIG=configs/sdkwork-api-cloud-gateway.portal.production.toml
